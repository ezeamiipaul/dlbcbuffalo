# ============================================
# 🌿 DLBC Buffalo Website — Git Ignore Config
# Tailwind CSS + Node + GitHub Pages
# ============================================

# Node dependencies
node_modules/

# Build output / caches
dist/*.map
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS-specific files
.DS_Store
Thumbs.db

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo

# Environment files (if you ever use them)
.env
.env.local
.env.*.local

# PostCSS and Tailwind cache
.cache/
.tailwind-cache/
.postcss-cache/

# Backup and temp files
*.tmp
*.bak
*.old

# Generated folders
coverage/
build/
out/
tmp/

# Local testing servers
serve.json

# Netlify / Vercel / Deployment configs (optional)
.vercel/
.netlify/
